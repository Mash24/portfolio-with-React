# Local development — copy to .env and restart `npm run dev`
# Vercel: Project Settings → Environment Variables → add the same key for Production

# Formspree form ID (https://formspree.io → New Form → copy the ID from the endpoint URL)
# Example endpoint: https://formspree.io/f/xyzabcde → use xyzabcde
VITE_FORMSPREE_FORM_ID=

# After adding on Vercel, redeploy for the contact form to submit in-page.
# Without this variable, the form falls back to opening the visitor's email client.
